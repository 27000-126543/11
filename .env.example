APP_NAME=EmployeeHealthManagement
APP_ENV=development
APP_PORT=8000

DATABASE_URL=sqlite:///./data/health_management.db

JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

LOG_LEVEL=INFO
LOG_DIR=./logs

HEALTH_DATA_COLLECTION_TIME=08:00
WEEKLY_REPORT_TIME=02:00
DEPARTMENT_MONITOR_INTERVAL=3600

ANOMALY_THRESHOLD_HEART_RATE_HIGH=20
ANOMALY_THRESHOLD_HEART_RATE_LOW=15
ANOMALY_THRESHOLD_STEPS_LOW=30
ANOMALY_THRESHOLD_SLEEP_LOW=25
ANOMALY_THRESHOLD_SLEEP_HIGH=20

DEPARTMENT_ANOMALY_ALERT_DAYS=3
DEPARTMENT_ANOMALY_ALERT_PERCENT=20

ADMIN_EMAIL=hr@company.com
